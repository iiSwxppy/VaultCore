<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Vault.Desktop.ViewModels"
        xmlns:views="using:Vault.Desktop.Views"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="Vault.Desktop.Views.MainWindow"
        x:DataType="vm:ShellViewModel"
        Width="960" Height="640"
        MinWidth="640" MinHeight="420"
        Title="VaultCore"
        WindowStartupLocation="CenterScreen">

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:UnlockViewModel}">
            <views:UnlockView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VaultViewModel}">
            <views:VaultView />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid RowDefinitions="*,Auto">
        <ContentControl Grid.Row="0" Content="{Binding CurrentPage}" />
        <Border Grid.Row="1" Padding="12,4"
                Background="#22808080"
                IsVisible="{Binding GlobalStatus, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Text="{Binding GlobalStatus}" FontSize="11" Opacity="0.75" />
        </Border>
    </Grid>
</Window>
