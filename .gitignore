# Build outputs
**/bin/
**/obj/
**/publish/
**/*.user
**/TestResults/
**/coverage/
**/*.coverage
**/*.coveragexml

# IDE
.vs/
.vscode/
.idea/
*.suo
*.userprefs
*.swp

# OS
.DS_Store
Thumbs.db
desktop.ini

# Node / extension build
extension/node_modules/
extension/dist/
extension/*.log

# Vault data — never commit.
*.vault
*.vault.tmp
*.vault.sync
*.vault.sync.tmp

# Local dev secrets / configs that aren't templates.
*.secret
*.key
.env
.env.local

# Native messaging host install outputs (manifest references local absolute paths).
src/Vault.Host/manifest.json
!src/Vault.Host/manifest.template.json

# AOT publish artifacts
**/*.pdb
**/*.dwarf

# Test outputs
*.trx
